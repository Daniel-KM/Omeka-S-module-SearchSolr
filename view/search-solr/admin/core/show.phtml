<?php if ($solrCore->userIsAllowed('update') && $solrCore->schema()->checkDefaultField()): ?>
<details id="search-config">
    <summary><?= $translate('Search configuration') ?></summary>
    <p class="explanation"><?= $translate('Configure the analyzer for the catchall field "_text_". This affects how search queries match indexed content.') ?></p>
    <?php
    $textFieldType = $solrCore->schema()->getFieldsByName()['_text_']['type'] ?? null;
    if ($textFieldType):
        $solrLanguages = include dirname(__DIR__, 4) . '/config/solr_languages.php';
        if ($textFieldType === 'text_search') {
            $currentLabel = $translate('optimized (Google-like search via EdgeNGram)');
        } elseif (preg_match('/^text_search_(\w+)$/', $textFieldType, $m) && isset($solrLanguages[$m[1]])) {
            $currentLabel = sprintf($translate('linguistic (%s)'), $solrLanguages[$m[1]]['label']);
        } else {
            $currentLabel = sprintf($translate('default (strict matching via "%s")'), $escape($textFieldType));
        }
    ?>
    <p class="explanation"><strong><?= sprintf($translate('Current configuration: %s.'), $currentLabel) ?></strong></p>
    <?php endif; ?>
    <form method="post" action="<?= $escape($solrCore->adminUrl('configure-search')) ?>">
        <div class="field">
            <div class="inputs">
                <label>
                    <input type="radio" name="search_config" value="keep" checked>
                    <?= $translate('Keep current configuration') ?>
